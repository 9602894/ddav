<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="2dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        card_view:cardCornerRadius="4dp"
        card_view:cardElevation="2dp"
        android:foreground="?android:attr/selectableItemBackground">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#ffffff">

            <!-- 缩略图 -->
            <ImageView
                android:id="@+id/iv_thumbnail"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />

            <!-- 视频标记 -->
            <ImageView
                android:id="@+id/iv_video_badge"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignTop="@+id/iv_thumbnail"
                android:layout_alignEnd="@+id/iv_thumbnail"
                android:layout_margin="6dp"
                android:src="@android:drawable/ic_media_play"
                android:visibility="gone"
                android:background="#88000000"
                android:padding="4dp" />

            <!-- 云朵标记（透明背景彩色） -->
            <TextView
                android:id="@+id/tv_cloud_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@+id/iv_thumbnail"
                android:layout_alignStart="@+id/iv_thumbnail"
                android:layout_margin="6dp"
                android:padding="2dp"
                android:text="☁️"
                android:textSize="24sp"
                android:textColor="@android:color/holo_blue_dark"
                android:background="@android:color/transparent"
                android:visibility="gone" />

            <!-- 手机标记（透明背景彩色） -->
            <TextView
                android:id="@+id/tv_local_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@+id/iv_thumbnail"
                android:layout_toEndOf="@+id/tv_cloud_badge"
                android:layout_margin="6dp"
                android:padding="2dp"
                android:text="📱"
                android:textSize="24sp"
                android:textColor="@android:color/holo_green_dark"
                android:background="@android:color/transparent"
                android:visibility="gone" />

            <!-- 文件名 -->
            <TextView
                android:id="@+id/tv_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/iv_thumbnail"
                android:padding="4dp"
                android:text=""
                android:textSize="11sp"
                android:textColor="#666666"
                android:singleLine="true"
                android:ellipsize="middle" />

            <!-- 复选框（右上角） -->
            <CheckBox
                android:id="@+id/cb_select"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignTop="@+id/iv_thumbnail"
                android:layout_alignEnd="@+id/iv_thumbnail"
                android:layout_margin="6dp"
                android:background="@android:color/white"
                android:button="@null"
                android:gravity="center"
                android:focusable="false"
                android:clickable="false" />

        </RelativeLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
